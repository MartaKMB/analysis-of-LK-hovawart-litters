      <aliases enabled='yes' />
      <column caption='More then one litter in lk' datatype='boolean' name='[Calculation_6237928394076160]' role='measure' type='nominal'>
        <calculation class='tableau' formula='COUNTD([miot]) &gt; 1' />
      </column>
      <column caption='Mother age for litter' datatype='integer' name='[Calculation_6260949428355072]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='FLOOR(DATEDIFF(&apos;day&apos;, [data urodzenia (suka-hodowlana)], [data urodzenia]) / 365.25)' />
      </column>
      <column caption='Week number' datatype='integer' name='[Calculation_6387943059034112]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Pivot Field Names] = &quot;birth_weight_puppy&quot; THEN 0&#10;ELSE INT(REGEXP_EXTRACT([Pivot Field Names], &apos;\d+&apos;))&#10;END' />
      </column>
      <column caption='Average puppies per litter' datatype='real' name='[Calculation_6703709333520384]' role='measure' type='quantitative'>
